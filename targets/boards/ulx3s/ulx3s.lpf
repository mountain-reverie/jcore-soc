# ULX3S (LFE5U-85F) — M0 BRAM+UART pins
LOCATE COMP "clk_25mhz" SITE "G2";
IOBUF  PORT "clk_25mhz" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk_25mhz" 25 MHz;

LOCATE COMP "ftdi_txd" SITE "L4";   # FPGA TX -> FTDI RX
IOBUF  PORT "ftdi_txd" IO_TYPE=LVCMOS33 PULLMODE=UP;
LOCATE COMP "ftdi_rxd" SITE "M1";   # FTDI TX -> FPGA RX
IOBUF  PORT "ftdi_rxd" IO_TYPE=LVCMOS33;

LOCATE COMP "btn[0]" SITE "D6";
LOCATE COMP "btn[1]" SITE "C7";
LOCATE COMP "btn[2]" SITE "A7";
LOCATE COMP "btn[3]" SITE "A8";
LOCATE COMP "btn[4]" SITE "C8";
LOCATE COMP "btn[5]" SITE "D8";
LOCATE COMP "btn[6]" SITE "D7";
IOBUF  PORT "btn[0]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;
IOBUF  PORT "btn[1]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;
IOBUF  PORT "btn[2]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;
IOBUF  PORT "btn[3]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;
IOBUF  PORT "btn[4]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;
IOBUF  PORT "btn[5]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;
IOBUF  PORT "btn[6]" IO_TYPE=LVCMOS33 PULLMODE=DOWN;

LOCATE COMP "led[0]" SITE "B2";
LOCATE COMP "led[1]" SITE "C2";
LOCATE COMP "led[2]" SITE "C1";
LOCATE COMP "led[3]" SITE "D1";
LOCATE COMP "led[4]" SITE "E2";
LOCATE COMP "led[5]" SITE "E1";
LOCATE COMP "led[6]" SITE "H3";
LOCATE COMP "led[7]" SITE "J3";
IOBUF  PORT "led[0]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[1]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[2]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[3]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[4]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[5]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[6]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF  PORT "led[7]" IO_TYPE=LVCMOS33 DRIVE=4;

# SDRAM (16-bit SDR; emard/ulx3s v2.0 pinout) — the J2's DEV_DDR main memory.
LOCATE COMP "sdram_clk"  SITE "F19";
LOCATE COMP "sdram_cke"  SITE "F20";
LOCATE COMP "sdram_csn"  SITE "P20";
LOCATE COMP "sdram_wen"  SITE "T20";
LOCATE COMP "sdram_rasn" SITE "R20";
LOCATE COMP "sdram_casn" SITE "T19";
LOCATE COMP "sdram_ba[0]" SITE "P19";
LOCATE COMP "sdram_ba[1]" SITE "N20";
LOCATE COMP "sdram_a[0]"  SITE "M20";
LOCATE COMP "sdram_a[1]"  SITE "M19";
LOCATE COMP "sdram_a[2]"  SITE "L20";
LOCATE COMP "sdram_a[3]"  SITE "L19";
LOCATE COMP "sdram_a[4]"  SITE "K20";
LOCATE COMP "sdram_a[5]"  SITE "K19";
LOCATE COMP "sdram_a[6]"  SITE "K18";
LOCATE COMP "sdram_a[7]"  SITE "J20";
LOCATE COMP "sdram_a[8]"  SITE "J19";
LOCATE COMP "sdram_a[9]"  SITE "H20";
LOCATE COMP "sdram_a[10]" SITE "N19";
LOCATE COMP "sdram_a[11]" SITE "G20";
LOCATE COMP "sdram_a[12]" SITE "G19";
LOCATE COMP "sdram_dqm[0]" SITE "U19";
LOCATE COMP "sdram_dqm[1]" SITE "E20";
LOCATE COMP "sdram_d[0]"  SITE "J16";
LOCATE COMP "sdram_d[1]"  SITE "L18";
LOCATE COMP "sdram_d[2]"  SITE "M18";
LOCATE COMP "sdram_d[3]"  SITE "N18";
LOCATE COMP "sdram_d[4]"  SITE "P18";
LOCATE COMP "sdram_d[5]"  SITE "T18";
LOCATE COMP "sdram_d[6]"  SITE "T17";
LOCATE COMP "sdram_d[7]"  SITE "U20";
LOCATE COMP "sdram_d[8]"  SITE "E19";
LOCATE COMP "sdram_d[9]"  SITE "D20";
LOCATE COMP "sdram_d[10]" SITE "D19";
LOCATE COMP "sdram_d[11]" SITE "C20";
LOCATE COMP "sdram_d[12]" SITE "E18";
LOCATE COMP "sdram_d[13]" SITE "F18";
LOCATE COMP "sdram_d[14]" SITE "J18";
LOCATE COMP "sdram_d[15]" SITE "J17";
IOBUF PORT "sdram_clk"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_cke"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_csn"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_wen"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_rasn" IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_casn" IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_ba[0]" IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_ba[1]" IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_a[0]"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_a[1]"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_a[2]"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
IOBUF PORT "sdram_a[3]"  IO_TYPE=LVCMOS33 DRIVE=4 SLEWRATE=FAST;
