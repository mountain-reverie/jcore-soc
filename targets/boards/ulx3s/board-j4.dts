/dts-v1/;

/ {
	model = "ulx3s";
	compatible = "jcore,j2-soc";
	#address-cells = <1>;
	#size-cells = <1>;
	interrupt-parent = <&aic>;

	aliases {
		serial0 = &uart;
	};

	chosen {
		stdout-path = "serial0:115200n8";
		bootargs = "console=ttyUL0 earlycon";
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;


		cpu@0 {
			device_type = "cpu";
			compatible = "jcore,j4";
			clock-frequency = <20000000>;
			reg = <0>;
		};
	};

	clocks {

		bus_clock: bus_clock {
			compatible = "fixed-clock";
			#clock-cells = <0>;
			clock-frequency = <20000000>;
		};
	};

	memory@10000000 {
		device_type = "memory";
		reg = <0x10000000 0x2000000>;
	};

	soc@abcd0000 {
		compatible = "simple-bus";
		ranges = <0x0 0xabcd0000 0x208>;
		#address-cells = <1>;
		#size-cells = <1>;

		timer {
			compatible = "jcore,pit";
			reg = <0x40 0x30>;
			interrupts = <0x10>;
		};

		gpio2 {
			compatible = "jcore,gpio2";
			reg = <0x0 0x10>; // ABCD0000-ABCD000F
		};

		aic: interrupt-controller {
			#interrupt-cells = <1>;
			compatible = "jcore,aic1";
			interrupt-controller;
			reg = <0x40 0x40>; // ABCD0040-ABCD007F
		};

		uart: serial {
			compatible = "jcore,uartlite", "xlnx,xps-uartlite-1.00.a";
			device_type = "serial";
			clock-frequency = <20000000>;
			current-speed = <115200>;
			reg = <0x100 0x10>; // ABCD0100-ABCD010F
		};

		spi {
			#address-cells = <1>;
			#size-cells = <0>;
			clock-names = "ref_clk";
			clocks = <&bus_clock>;
			compatible = "jcore,spi2";
			spi-max-frequency = <25000000>;
			status = "ok";
			reg = <0x200 0x8>; // ABCD0200-ABCD0207

			sdcard@0 {
				compatible = "mmc-spi-slot";
				reg = <0>;
				spi-max-frequency = <25000000>;
				voltage-ranges = <3200 3400>;
				mode = <0>;
			};

			m25p80@1 {
				compatible = "s25fl164k", "jedec,spi-nor";
				#address-cells = <1>;
				#size-cells = <1>;
				spi-max-frequency = <25000000>;
				reg = <1>;
				mode = <0>;
				m25p,fast-read;

				partition@0 {
					label = "spi_flash";
					reg = <0 0>;
				};
			};
		};
	};

	cpuid {
		compatible = "jcore,cpuid-mmio";
		reg = <0xabcd0600 0x4>;
	};
};
